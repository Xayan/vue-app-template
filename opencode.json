{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "serena-agent": {
      "type": "local",
      "command": [
        "uvx",
        "-p",
        "3.13",
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "vue-app-template"
      ],
      "enabled": true,
      "timeout": 30000
    }
  }
}
